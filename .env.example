# ===== TELEGRAM =====
BOT_TOKEN=
ADMIN_ID=
BOT_NAME=Дух
BOT_TRIGGER=дух,духи,духа,духу,spirit,duh

# ===== ГЛАВНЫЙ AI: Claude Sonnet 4.6 через OpenRouter =====
OPENROUTER_KEY=
# Можно несколько ключей для ротации квот:
# OPENROUTER_KEY_2=
# OPENROUTER_KEY_3=
CLAUDE_MODEL=anthropic/claude-sonnet-4.6
# Fallback модели если Claude упал (через запятую, в порядке предпочтения)
FALLBACK_MODELS=google/gemini-2.5-flash,meta-llama/llama-3.3-70b-instruct:free

# ===== GEMINI: vision + audio + embeddings (БЕСПЛАТНО) =====
GEMINI_KEY=
# Ротация ключей для обхода квот:
# GEMINI_KEY_2=
# GEMINI_KEY_3=
GEMINI_VISION_MODEL=gemini-2.0-flash
GEMINI_AUDIO_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# ===== GROQ: распознавание голоса (Whisper, бесплатно) =====
GROQ_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# ===== ПОИСК В ИНТЕРНЕТЕ =====
TAVILY_KEY=
# Альтернатива — Perplexity через OpenRouter (использует OPENROUTER_KEY):
# PERPLEXITY_MODEL=perplexity/sonar
SEARCH_PROVIDER=tavily
SEARCH=true

# ===== ГЕНЕРАЦИЯ КАРТИНОК =====
IMAGES=true
IMAGEGEN_PROVIDER=pollinations

# ===== БД (Railway даёт автоматически когда добавляешь Postgres плагин) =====
DATABASE_URL=

# ===== ФИЧИ =====
VISION=true
VOICE=true
AUDIO=true
REACTIONS=false
AUTO_REVIVE=true
AUTO_REVIVE_HOURS=3
BAN_ENABLED=true

# ===== ПОВЕДЕНИЕ =====
HISTORY_LIMIT=30
PROMPT_CACHE=true
PRIVATE_CHAT_ADMIN_ONLY=false
ADMIN_MUST_BE_IN_GROUP=false
TYPING_DELAY_MS=600
SEMANTIC_RECALL_K=5
